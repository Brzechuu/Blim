package main

use math

#vec main 0

Vector: struct {
    x: i16
    y: i16
}

vector1: Vector = { 1, 2 }

text: u16[13] = "Hello, World!"

main: fun() {
    vector2: Vector

    vector2.x = -1
    vector2.y = 5

    sum_x: i16 = math.add_i16(vector1.x, vector2.x)
    sum_y: i16 = vector1.y + vector2.y

    i: u16 = 0
    while(i < 13) {
        print(text[i])
        i = i + 1
    }
    asm { hlt }
}

print: fun(x: u16) {
    asm {
        out a0, r0
    }
}
